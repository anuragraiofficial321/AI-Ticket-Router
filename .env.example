# Copy this file to .env and fill in your free API key(s).
# You only need ONE LLM provider below, plus (optionally) audio keys.

# =========================================================
# Database (user accounts + per-user ticket history)
# =========================================================
# Optional. Defaults to ./data/ticket_router.db (mounted as a Docker volume so it
# survives rebuilds). Only set this if you want the SQLite file somewhere else.
# DB_PATH=/app/data/ticket_router.db

# =========================================================
# LLM (ticket classification / priority / response drafting)
# =========================================================

# --- Groq (recommended, free & fast) ---
# Get a key at https://console.groq.com/keys
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=your_groq_api_key_here
LLM_MODEL=llama-3.1-8b-instant

# --- OpenRouter (free-tagged models) ---
# Get a key at https://openrouter.ai/keys
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=your_openrouter_api_key_here
# LLM_MODEL=meta-llama/llama-3.1-8b-instruct:free

# --- Google Gemini (OpenAI-compatible endpoint) ---
# Get a key at https://aistudio.google.com/apikey
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# LLM_API_KEY=your_gemini_api_key_here
# LLM_MODEL=gemini-2.0-flash

# --- Ollama (local, no key needed, no cost) ---
# Install from https://ollama.com and run: ollama pull llama3
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=
# LLM_MODEL=llama3

# =========================================================
# Speech-to-Text (voice ticket input)
# =========================================================
# Defaults to Groq's free Whisper endpoint. Leaving STT_API_KEY blank reuses
# LLM_API_KEY automatically, which is what you want when Groq powers both.
STT_BASE_URL=https://api.groq.com/openai/v1
STT_MODEL=whisper-large-v3-turbo
STT_API_KEY=

# =========================================================
# Text-to-Speech (listen to suggested responses)
# =========================================================
# Runs on Groq's OpenAI-compatible /audio/speech endpoint. Leaving TTS_API_KEY blank
# reuses LLM_API_KEY automatically — the same free Groq key covers chat, Whisper and
# speech. Do NOT put an ElevenLabs sk_... key here; Groq rejects it with 401.
#
# IMPORTANT: Groq TTS models require a ONE-TIME terms acceptance before they work.
# Visit https://console.groq.com/playground?model=canopylabs%2Forpheus-v1-english
# and accept, otherwise calls fail with "model_terms_required" and the app falls
# back to the free Edge voice.
TTS_API_KEY=
TTS_BASE_URL=https://api.groq.com/openai/v1
TTS_MODEL=canopylabs/orpheus-v1-english
# Voices: autumn, diana, hannah, austin, daniel, troy
TTS_VOICE=autumn
# Orpheus returns WAV only — mp3/flac are rejected with a 400.
TTS_FORMAT=wav

# Free, no-key fallback voice. Used automatically whenever the Groq TTS call fails —
# including before you accept the model terms above — so audio playback never breaks.
# Try en-US-AriaNeural, en-GB-SoniaNeural, en-US-GuyNeural.
EDGE_TTS_VOICE=en-US-AriaNeural
